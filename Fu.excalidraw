      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- we solve this problem using promise chain\n\nlogin()\n.then(getUsers)\n.then(getOrders)\n.then(getPayment)\n.then(GetAddress)\n.catch((err)=>{\nconsole.log(err);\n});",
      "autoResize": true,
