      "updated": 1781671940925,
      "link": null,
      "locked": false,
      "text": "Syntax of Promise:\n    \n    const promise = new Promise((resolve, reject)=>{\n        resolve(\"Data Found\");\n    });",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Syntax of Promise:\n    \n    const promise = new Promise((resolve, reject)=>{\n        resolve(\"Data Found\");\n    });",
      "autoResize": true,
      "lineHeight": 1.25
    },
