      "isDeleted": false,
      "boundElements": [],
      "updated": 1781247218824,
      "link": null,
      "locked": false,
      "text": "-> querySelector : For selecting one element at a time and first occuring as well.\n\n-> querSelectorAll : For selecting all elements at a time.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> querySelector : For selecting one element at a time and first occuring as well.\n\n-> querSelectorAll : For selecting all elements at a time.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "9On-FkDwGkNi0bEYwJ36b",
      "type": "text",
      "x": 1065.7256167288824,
      "y": 10080.523948315482,
      "width": 1983.538818359375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCj",
      "roundness": null,
      "seed": 1436696235,
      "version": 3,
      "versionNonce": 1727109771,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781247038665,
      "link": null,
      "locked": false,
      "text": "DOM stands for Document Object Model, a programming interface that represents a web page as a structured tree of objects, allowing scripts to access and manipulate its content, structure, and style.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DOM stands for Document Object Model, a programming interface that represents a web page as a structured tree of objects, allowing scripts to access and manipulate its content, structure, and style.",
      "autoResize": true,
      "lineHeight": 1.25
    },
