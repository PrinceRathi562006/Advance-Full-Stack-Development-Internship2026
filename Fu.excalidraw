      "text": "Login -> Get Users -> Get orders -> Get payment -> Get address\n\nlogin(function(){\n    getUsers(function(){\n        getOrders(function(){\n            getPayment(function(){\n                GetAddress(function(){\n                })\n            })\n        })\n    }\n)\n});",
