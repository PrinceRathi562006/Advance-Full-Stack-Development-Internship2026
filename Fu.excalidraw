    {
      "id": "Irc5UfvdSq1mzHmsRsXEE",
      "type": "text",
      "x": 468.92559841833554,
      "y": 5264.823905400138,
      "width": 1170.879150390625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1971c2",
