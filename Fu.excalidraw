      "link": null,
      "locked": false,
      "text": "Resolve and reject are built in function in JavaScript.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Resolve and reject are built in function in JavaScript.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xChiuYUewTNvpNqgHowK2",
      "type": "text",
      "x": -96.2767610430297,
      "y": 17652.594635195255,
      "width": 520.6196899414062,
      "height": 425,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFF",
      "roundness": null,
      "seed": 829481425,
      "version": 381,
      "versionNonce": 907101791,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781672399452,
      "link": null,
      "locked": false,
      "text": "// How to handle resolve ->\n\npromise.then((data)=>{\n    console.log(data);\n});\n\n// How to handle reject in promise ->\n\n- for handling reject we have to use .catch() method.\n\nconst promise = new Promise((resolve, reject) => {\n    reject(\"Network error\");\n});\n\npromise.catch((error)=>{\n    console.log(error);\n});",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// How to handle resolve ->\n\npromise.then((data)=>{\n    console.log(data);\n});\n\n// How to handle reject in promise ->\n\n- for handling reject we have to use .catch() method.\n\nconst promise = new Promise((resolve, reject) => {\n    reject(\"Network error\");\n});\n\npromise.catch((error)=>{\n    console.log(error);\n});",
