      "seed": 1989160683,
      "version": 306,
      "versionNonce": 985186475,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781247689764,
      "link": null,
      "locked": false,
      "text": "1. click.\n\n2. Double click.\n\n3. Typing.\n\n4. hover.\n\n5. submit.\n\n6. scroll.\n\n7. resize.\n\n8. drag.\n\n9. drop.\n\nall of these are events -\n\n-> addEventListner :-\n\n    element.addEventListner(\n        eventName,\n        callbackFunction\n    );",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. click.\n\n2. Double click.\n\n3. Typing.\n\n4. hover.\n\n5. submit.\n\n6. scroll.\n\n7. resize.\n\n8. drag.\n\n9. drop.\n\nall of these are events -\n\n-> addEventListner :-\n\n    element.addEventListner(\n        eventName,\n        callbackFunction\n    );",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "1yUDYDkhalNu_HtH0fztq",
      "type": "text",
      "x": 379.52560452185116,
      "y": 12168.523948315482,
      "width": 414.99969482421875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
