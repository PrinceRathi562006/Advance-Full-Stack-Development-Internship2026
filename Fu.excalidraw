    {
      "id": "8RijlNAy8BOdioAXMG5oQ",
      "type": "text",
      "x": 444.3999938964844,
      "y": 3658.5,
      "width": 1087.2391357421875,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
