    {
      "id": "qO2chQiiCjWrry6rIodOx",
      "type": "text",
      "x": -78.17842787645168,
      "y": 17619.112810314466,
      "width": 520.2196044921875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
