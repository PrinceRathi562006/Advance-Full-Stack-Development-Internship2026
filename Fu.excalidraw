    },
    {
      "id": "IHrDILKrWve_gcl1cEylk",
      "type": "text",
      "x": -99.02107454055863,
      "y": 16796.851799975702,
      "width": 1290.6192626953125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bEu",
      "roundness": null,
      "seed": 65001553,
      "version": 8,
      "versionNonce": 197395633,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781671225702,
      "link": null,
      "locked": false,
      "text": "Callback hell (also known as the Pyramid of Doom) is a phenomenon in JavaScript \nwhere multiple nested callback functions are chained together to handle sequential asynchronous operations, \nmaking the code incredibly difficult to read, debug, and maintain.\nIt occurs because JavaScript is single-threaded and executes code non-blocking, \nmeaning operations that take time (like database queries or API requests) require callbacks to execute tasks in a specific sequence",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Callback hell (also known as the Pyramid of Doom) is a phenomenon in JavaScript \nwhere multiple nested callback functions are chained together to handle sequential asynchronous operations, \nmaking the code incredibly difficult to read, debug, and maintain.\nIt occurs because JavaScript is single-threaded and executes code non-blocking, \nmeaning operations that take time (like database queries or API requests) require callbacks to execute tasks in a specific sequence",
      "autoResize": true,
      "lineHeight": 1.25
    },
