      "seed": 108712427,
      "version": 7,
      "versionNonce": 607064229,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781247710701,
      "link": null,
      "locked": false,
      "text": "-> how an EventListner works internally :--",
      "fontSize": 20,
