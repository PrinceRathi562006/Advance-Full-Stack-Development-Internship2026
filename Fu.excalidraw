      "updated": 1781586276359,
      "link": null,
      "locked": false,
      "text": "-> JS = Synchronous single threaded language.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> JS = Synchronous single threaded language.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "rFiye4mGxuV8Qh6OMTspM",
      "type": "text",
      "x": 445.32562283239804,
      "y": 13251.923942211966,
      "width": 988.399658203125,
      "height": 35,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDS",
      "roundness": null,
      "seed": 1804633493,
      "version": 74,
      "versionNonce": 57127195,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "5ztn_M--W39lhOl9pPmss",
          "type": "arrow"
        }
      ],
      "updated": 1781586306037,
      "link": null,
      "locked": false,
      "text": "It's meant that there is only one thread and inside that your code runs",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's meant that there is only one thread and inside that your code runs",
      "autoResize": true,
      "lineHeight": 1.25
    },
