    },
    {
      "id": "lrjwWMb_May3WrTv4qiME",
      "type": "text",
      "x": 637.4611438915556,
      "y": 16551.682664712265,
      "width": 277.25982666015625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1971c2",
