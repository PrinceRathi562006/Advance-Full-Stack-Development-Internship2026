    {
      "id": "Yw9wZFkwb4rbw-WMjO9EX",
      "type": "text",
      "x": -114.70000251824035,
      "y": 17078.183995438572,
      "width": 1207.7991943359375,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bF2",
      "roundness": null,
      "seed": 587367519,
      "version": 303,
      "versionNonce": 1588438655,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781671720252,
      "link": null,
      "locked": false,
      "text": "-> A promise is an object that represents a future result. that is not given till now but in future it will definately provided.\n\nIt comes with 3 states :-\n\n1. Pending - abhi result nahi aaya h.\n2. Fullfilled (Resolved) - kam sucessfull.\n3. Rejected - kaam fail.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> A promise is an object that represents a future result. that is not given till now but in future it will definately provided.\n\nIt comes with 3 states :-\n\n1. Pending - abhi result nahi aaya h.\n2. Fullfilled (Resolved) - kam sucessfull.\n3. Rejected - kaam fail.",
      "autoResize": true,
      "lineHeight": 1.25
    },
