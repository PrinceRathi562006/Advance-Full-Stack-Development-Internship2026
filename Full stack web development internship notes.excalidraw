      "version": 74,
      "versionNonce": 57127195,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "5ztn_M--W39lhOl9pPmss",
          "type": "arrow"
        }
      ],
      "updated": 1781586306037,
      "link": null,
      "locked": false,
      "text": "It's meant that there is only one thread and inside that your code runs",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's meant that there is only one thread and inside that your code runs",
      "autoResize": true,
      "lineHeight": 1.25
    },
