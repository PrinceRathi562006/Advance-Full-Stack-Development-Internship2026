      "boundElements": [],
      "updated": 1781240924373,
      "link": null,
      "locked": false,
      "text": "try{\n\n// Whatever work you have to do—do it.\n\n} catch(error){\n\n// if work not done properly then show error.\n\n} finally{\n// it will always work, it not matter try or catch block run or not.\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "try{\n\n// Whatever work you have to do—do it.\n\n} catch(error){\n\n// if work not done properly then show error.\n\n} finally{\n// it will always work, it not matter try or catch block run or not.\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
