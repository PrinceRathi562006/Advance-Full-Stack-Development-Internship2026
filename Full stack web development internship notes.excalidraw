      "versionNonce": 1864901221,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781241487051,
      "link": null,
      "locked": false,
      "text": "-> let we have a project with 5000 lines of code, with jobs like login, signup, order, order-history,\n    dispatch, order-review,.... and more.\n-> in this project we will create separate files for each jobs to perform.\n-> by this way when ever a error occur in a single job then it will not effect other jobs.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "-> let we have a project with 5000 lines of code, with jobs like login, signup, order, order-history,\n    dispatch, order-review,.... and more.\n-> in this project we will create separate files for each jobs to perform.\n-> by this way when ever a error occur in a single job then it will not effect other jobs.",
      "autoResize": true,
      "lineHeight": 1.25
    },
