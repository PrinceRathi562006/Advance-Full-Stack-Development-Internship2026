    {
      "id": "zUm45g-YPgcJ9CFd5Vrik",
      "type": "text",
      "x": 345.72564724646054,
      "y": 8604.423911503654,
      "width": 1291.21923828125,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bBc",
      "roundness": null,
      "seed": 1543550123,
      "version": 385,
      "versionNonce": 1121143275,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781240052058,
      "link": null,
      "locked": false,
      "text": "Error -> \n\nTypes of Error - \n\n    1. Reference Error : The variable doesn't even exist.\n\n    2. Type Error : This means the operation is being performed with the wrong data type, resulting in a type error.\n\n    3. Syntax Error : not follow set of rules to write code in a language or we can say that program grammar is not written correct.\n    \n    4. Range Error :  When we exceed the range already defined. or, out of bound\n\n    5. Run time Error : A runtime error is a coding mistake that crashes a program while it is running.\n            The code itself has correct grammar and successfully starts up, but it stops working when it hits an impossible command.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Error -> \n\nTypes of Error - \n\n    1. Reference Error : The variable doesn't even exist.\n\n    2. Type Error : This means the operation is being performed with the wrong data type, resulting in a type error.\n\n    3. Syntax Error : not follow set of rules to write code in a language or we can say that program grammar is not written correct.\n    \n    4. Range Error :  When we exceed the range already defined. or, out of bound\n\n    5. Run time Error : A runtime error is a coding mistake that crashes a program while it is running.\n            The code itself has correct grammar and successfully starts up, but it stops working when it hits an impossible command.",
      "autoResize": true,
      "lineHeight": 1.25
    },
