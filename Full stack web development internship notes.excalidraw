    {
      "id": "u10tAZqZ3MudcXyoLwq_G",
      "type": "text",
      "x": 883.1256411429449,
      "y": 13838.524009350638,
      "width": 505.25933837890625,
      "height": 550,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bDt",
