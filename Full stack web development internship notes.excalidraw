      "text": "function greet (name=\"Guest\"){\n    console.log(name);\n}\n\ngreet(); // default output\ngreet(\"Pravin\") // output given parameter\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "function greet (name=\"Guest\"){\n    console.log(name);\n}\n\ngreet(); // default output\ngreet(\"Pravin\") // output given parameter\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6hKWGQcA2UgkxkjnKL-Fh",
      "type": "text",
      "x": 417.8000183105469,
