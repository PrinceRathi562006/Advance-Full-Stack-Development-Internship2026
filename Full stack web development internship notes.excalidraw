      "text": "{\n    tagName:\"html\",\n    children:[\n        {\n            tagName:\"head\"\n        },\n        {\n            tagName:\"body\",\n            children:[\n                {tagName:\"h1\", text:\"My First Page\"},\n                {tagName:\"p\", text:\"This is a paragraph\"},\n                {tagName:\"img:src:\"url\" alttext:\"my page image\"}\n            ]\n          }\n    ]\n}\n            ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "{\n    tagName:\"html\",\n    children:[\n        {\n            tagName:\"head\"\n        },\n        {\n            tagName:\"body\",\n            children:[\n                {tagName:\"h1\", text:\"My First Page\"},\n                {tagName:\"p\", text:\"This is a paragraph\"},\n                {tagName:\"img:src:\"url\" alttext:\"my page image\"}\n            ]\n          }\n    ]\n}\n            ",
