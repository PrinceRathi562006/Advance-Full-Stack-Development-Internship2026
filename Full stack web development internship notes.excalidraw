    {
      "id": "vZuQZBVGnJjGpie_yhZqn",
      "type": "text",
      "x": 372.52560452185116,
      "y": 10942.123954418998,
      "width": 1052.699462890625,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCm",
