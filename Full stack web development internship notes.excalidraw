    {
      "id": "V5LhQZqKpr-SnioxHxTWw",
      "type": "text",
      "x": 392.52560452185116,
      "y": 11491.523948315482,
      "width": 277.6998291015625,
      "height": 650,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
